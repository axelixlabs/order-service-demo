    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Rate — requests/s by endpoint",
      "description": "R in RED: throughput served per endpoint (uri template), requests per second.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
