          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(http_server_requests_seconds_count{application=\"order-service\", uri=\"$uri\", status=~\"5..\"}[$__rate_interval])) / sum(rate(http_server_requests_seconds_count{application=\"order-service\", uri=\"$uri\"}[$__rate_interval]))",
          "legendFormat": "5xx (server)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(http_server_requests_seconds_count{application=\"order-service\", uri=\"$uri\", status=~\"4..\"}[$__rate_interval])) / sum(rate(http_server_requests_seconds_count{application=\"order-service\", uri=\"$uri\"}[$__rate_interval]))",
          "legendFormat": "4xx (client)"
        }
